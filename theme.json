{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "palette": [
        { "slug": "r8-primary",          "color": "#28BAE0", "name": "Open Sky" },
        { "slug": "r8-primary-dark",     "color": "#0A6E8F", "name": "Deep Current" },
        { "slug": "r8-secondary",        "color": "#3DB87A", "name": "Living Green" },
        { "slug": "r8-tertiary",         "color": "#607080", "name": "Watershed" },
        { "slug": "r8-surface",          "color": "#F2F7F8", "name": "Morning Mist" },
        { "slug": "r8-surface-variant",  "color": "#F0F4F8", "name": "Surface Variant" },
        { "slug": "r8-background",       "color": "#FFFFFF", "name": "Background" },
        { "slug": "r8-on-surface",       "color": "#1C2D30", "name": "Midnight Grove" },
        { "slug": "r8-on-surface-muted", "color": "#5F6368", "name": "On Surface Muted" },
        { "slug": "r8-error",            "color": "#B00020", "name": "Error" },
        { "slug": "r8-success",          "color": "#00695C", "name": "Success" }
      ],
      "gradients": [
        {
          "slug": "r8-primary-gradient",
          "gradient": "linear-gradient(135deg, #0A6E8F 0%, #28BAE0 100%)",
          "name": "Rezon8 Primary Gradient"
        },
        {
          "slug": "r8-accent-gradient",
          "gradient": "linear-gradient(135deg, #3DB87A 0%, #28BAE0 100%)",
          "name": "Rezon8 Accent Gradient"
        }
      ],
      "duotone": [],
      "custom": true,
      "customDuotone": false,
      "customGradient": true,
      "defaultGradients": false,
      "defaultPalette": false,
      "link": true
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Raleway', system-ui, sans-serif",
          "slug": "raleway",
          "name": "Raleway (Display)"
        },
        {
          "fontFamily": "'DM Sans', system-ui, sans-serif",
          "slug": "dm-sans",
          "name": "DM Sans (Body)"
        },
        {
          "fontFamily": "'Playfair Display', Georgia, serif",
          "slug": "playfair-display",
          "name": "Playfair Display (Accent)"
        },
        {
          "fontFamily": "'Roboto Mono', 'Courier New', monospace",
          "slug": "roboto-mono",
          "name": "Roboto Mono"
        }
      ],
      "fontSizes": [
        { "slug": "label-sm",    "size": "0.6875rem", "name": "Label Small" },
        { "slug": "label-lg",    "size": "0.875rem",  "name": "Label Large" },
        { "slug": "body-md",     "size": "0.875rem",  "name": "Body Medium" },
        { "slug": "body-lg",     "size": "1rem",      "name": "Body Large" },
        { "slug": "title-sm",    "size": "0.875rem",  "name": "Title Small" },
        { "slug": "title-md",    "size": "1rem",      "name": "Title Medium" },
        { "slug": "title-lg",    "size": "1.375rem",  "name": "Title Large" },
        { "slug": "headline-sm", "size": "1.5rem",    "name": "Headline Small" },
        { "slug": "headline-md", "size": "1.75rem",   "name": "Headline Medium" },
        { "slug": "headline-lg", "size": "2rem",      "name": "Headline Large" },
        { "slug": "display-sm",  "size": "2.25rem",   "name": "Display Small" },
        { "slug": "display-md",  "size": "2.8125rem", "name": "Display Medium" },
        { "slug": "display-lg",  "size": "3.5625rem", "name": "Display Large" }
      ],
      "fluid": true,
      "customFontSize": true,
      "dropCap": false,
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "textDecoration": true,
      "textTransform": true,
      "writingMode": false
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      },
      "units": [ "px", "em", "rem", "%", "vw", "vh" ],
      "padding": true,
      "margin": true,
      "blockGap": true,
      "customSpacingSize": true
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "shadow": {
      "presets": [
        { "slug": "elevation-1", "shadow": "0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24)", "name": "Elevation 1" },
        { "slug": "elevation-2", "shadow": "0 3px 6px rgba(0,0,0,0.15), 0 2px 4px rgba(0,0,0,0.12)", "name": "Elevation 2" },
        { "slug": "elevation-3", "shadow": "0 10px 20px rgba(0,0,0,0.15), 0 3px 6px rgba(0,0,0,0.10)", "name": "Elevation 3" },
        { "slug": "elevation-4", "shadow": "0 14px 28px rgba(0,0,0,0.18), 0 10px 10px rgba(0,0,0,0.12)", "name": "Elevation 4" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--r8-background)",
      "text": "var(--wp--preset--color--r8-on-surface)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--dm-sans)",
      "fontSize": "var(--wp--preset--font-size--body-lg)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--r8-primary)" },
        ":hover": {
          "color": { "text": "var(--wp--preset--color--r8-primary-light)" }
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--display-sm)",
          "fontWeight": "400",
          "letterSpacing": "-0.025em",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--headline-lg)",
          "fontWeight": "400",
          "letterSpacing": "-0.015em",
          "lineHeight": "1.25"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--headline-md)",
          "fontWeight": "500",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--headline-sm)",
          "fontWeight": "500",
          "lineHeight": "1.35"
        }
      },
      "button": {
        "border": { "radius": "4px" },
        "color": {
          "background": "var(--wp--preset--color--r8-primary)",
          "text": "#FFFFFF"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--raleway)",
          "fontSize": "var(--wp--preset--font-size--label-lg)",
          "fontWeight": "500",
          "letterSpacing": "0.0892857em",
          "textTransform": "uppercase"
        },
        "spacing": {
          "padding": { "top": "0.625rem", "bottom": "0.625rem", "left": "1.5rem", "right": "1.5rem" }
        }
      }
    }
  },
  "customTemplates": [],
  "templateParts": [],
  "patterns": []
}
